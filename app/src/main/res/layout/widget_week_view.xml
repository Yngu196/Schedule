<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget_white"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tv_widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_widget_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#666666"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:minHeight="80dp">

        <!-- 周一 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_mon_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周一"
                android:textSize="10sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_mon_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#888888"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_mon_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:padding="3dp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- 周二 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_tue_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周二"
                android:textSize="10sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_tue_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#888888"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_tue_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:padding="3dp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- 周三 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_wed_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周三"
                android:textSize="10sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_wed_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#888888"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_wed_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:padding="3dp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- 周四 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_thu_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周四"
                android:textSize="10sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_thu_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#888888"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_thu_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:padding="3dp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- 周五 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_fri_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周五"
                android:textSize="10sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_fri_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#888888"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_fri_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:padding="3dp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- 周六 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_sat_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周六"
                android:textSize="10sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_sat_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#888888"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_sat_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:padding="3dp"
                android:background="#E0E0E0" />
        </LinearLayout>

        <!-- 周日 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/tv_sun_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="周日"
                android:textSize="10sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_sun_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#888888"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_sun_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:padding="3dp"
                android:background="#E0E0E0" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>