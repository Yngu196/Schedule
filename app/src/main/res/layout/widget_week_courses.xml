<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget_white"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tv_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="本周课程"
            android:textSize="11sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tv_widget_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="第1周"
            android:textSize="10sp"
            android:textColor="#888888" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="60dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_course_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无课程"
            android:textSize="13sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_course_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/tv_course_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp">

        <TextView
            android:id="@+id/tv_widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="4月22日 周三"
            android:textSize="9sp"
            android:textColor="#999999" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 x 2"
            android:textSize="10sp"
            android:textColor="#CCCCCC" />
    </LinearLayout>

</LinearLayout>