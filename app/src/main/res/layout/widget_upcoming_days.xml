<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget_white"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tv_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="11sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tv_widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#4A90E2" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:minHeight="70dp">

        <!-- 今日课程（左半） -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/tv_today_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今天"
                android:textSize="12sp"
                android:textColor="#4A90E2"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <ListView
                android:id="@+id/lv_today_courses"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="true"
                android:scrollbarFadeDuration="1500"
                android:scrollbarStyle="outsideOverlay"
                android:listSelector="@android:color/transparent" />
        </LinearLayout>

        <!-- 明天课程（右半） -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="6dp">

            <TextView
                android:id="@+id/tv_tomorrow_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="明天"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingBottom="4dp" />

            <ListView
                android:id="@+id/lv_tomorrow_courses"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="true"
                android:scrollbarFadeDuration="1500"
                android:scrollbarStyle="outsideOverlay"
                android:listSelector="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
