<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请输入学校名称"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_custom_school_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="例如：某某大学"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请输入教务系统登录网址"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_custom_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="例如：https://jw.xxxx.edu.cn"
        android:inputType="textUri"
        android:maxLines="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="提示：输入学校教务系统的登录页面地址，应用将自动尝试解析课程表。"
        android:textSize="12sp"
        android:textColor="#999999"
        android:layout_marginTop="8dp" />

</LinearLayout>