<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget_white"
    android:padding="10dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tv_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="本学期"
            android:textSize="11sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tv_widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="今日"
            android:textSize="12sp"
            android:textColor="#4A90E2"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_widget_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="#888888"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- 课程列表 ListView：支持上下滑动 -->
    <ListView
        android:id="@+id/lv_today_courses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="60dp"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:listSelector="@android:color/transparent" />

    <!-- 底部信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日课程"
            android:textSize="9sp"
            android:textColor="#999999" />

        <TextView
            android:id="@+id/tv_widget_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="上下滑动查看更多"
            android:textSize="9sp"
            android:textColor="#CCCCCC" />
    </LinearLayout>

</LinearLayout>
